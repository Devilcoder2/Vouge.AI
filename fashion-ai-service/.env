# Host and Server Configuration
HOST=0.0.0.0
PORT=8000

# Database Configuration
# Direct connections use psycopg2-binary, async calls use asyncpg
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/vouge
DB_URL_SYNC=postgresql://postgres:postgres@localhost:5432/vouge

# AI Service Configuration
# Replace with your actual Gemini API Key from Google AI Studio
GEMINI_API_KEY=AIzaSyDsex5VAIdGk8RwpUltqKJDych1hN6kPkw
CLIP_MODEL_NAME=openai/clip-vit-base-patch32

# File Storage Configuration
UPLOAD_DIR=uploads
PROCESSED_DIR=processed
EMBEDDING_DIR=embeddings
MAX_CONTENT_LENGTH=10485760  # 10MB limit in bytes
ALLOWED_EXTENSIONS=jpg,jpeg,png

# JWT Authentication
JWT_SECRET_KEY=06359b33e38c177fa38ccaa5eb3fcaa04d762ccb1c5fa5bafaa35a1d99ef8ab9
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Async Background Processing
REDIS_URL=redis://localhost:6379/0
USE_CELERY=true

# AWS S3 Cloud Storage
USE_S3=false
AWS_ACCESS_KEY_ID=mock_key
AWS_SECRET_ACCESS_KEY=mock_secret
AWS_S3_BUCKET_NAME=vouge-assets
AWS_S3_REGION_NAME=us-east-1
AWS_S3_ENDPOINT_URL=
CDN_BASE_URL=
